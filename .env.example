# Copie para .env e preencha (nao commitar .env)
# VITE_BACKFILL_SECRET = mesmo valor do secret META_SYNC_SECRET no Firebase Functions
#
# Teste local API (scripts/test-shopee-mes.cjs) — mesmos secrets das Functions:
# SHOPEE_APP_ID=
# SHOPEE_SECRET=

# Functions (Firebase): modo de agregacao — definido em functions/.env.projetoafiliado-9ff07
# (aplicado no deploy; nao precisa abrir Google Cloud Console)
# promosapp = node_once (batimento PromosApp) | api = api-faithful-v2

# Front: KPIs sempre de shopee_daily com logica PromosApp (1=padrao, 0=cache mensal)
# VITE_SHOPEE_PROMOSAPP_KPI=1
# Front: 0 = sem snap. 1 = snap legado api-faithful (so meses antigos nao re-sincronizados)
# VITE_SHOPEE_PROMOSAPP_COMISSAO=0
# Opcional: fator fino no pendente (ex. 0.9362) se ainda faltar centavos vs PromosApp
# VITE_SHOPEE_PROMOSAPP_PEND_FACTOR=0.9362

# 0 = KPIs somam Firestore/API (padrao). 1 = snap ao painel Shopee no mes com meta em config/shopee_oficial
VITE_SHOPEE_ALIGN_PANEL=0
# 0 = só Firestore/API (padrao). 1 = força totais da planilha CSV no mes com ref
VITE_SHOPEE_SNAP_CSV_BATIMENTO=0

VITE_BACKFILL_URL=https://shopeebackfillnow-ncjpjjcdya-rj.a.run.app
VITE_BACKFILL_SECRET=seu-meta-sync-secret-aqui
# Opcional — se omitido, deriva de VITE_BACKFILL_URL (shopeebackfillnow → metabackfilldaily)
VITE_META_DAILY_URL=https://metabackfilldaily-ncjpjjcdya-rj.a.run.app
VITE_LOOKUP_URL=https://shopeeproductlookup-ncjpjjcdya-rj.a.run.app
VITE_REFRESH_URL=https://shopeebackuprefreshnow-ncjpjjcdya-rj.a.run.app
VITE_GROUP_REFRESH_URL=https://shopeebackuprefreshgroupnow-ncjpjjcdya-rj.a.run.app
VITE_SIMILARES_URL=https://shopeebackupsimilaresshop-ncjpjjcdya-rj.a.run.app
# Garimpo contextual por palavra-chave (productOfferV2) — deploy: shopeeGarimpoKeyword
VITE_GARIMPO_KEYWORD_URL=https://southamerica-east1-projetoafiliado-9ff07.cloudfunctions.net/shopeeGarimpoKeyword
# Proxy GraphQL afiliados (productOfferV2, generateShortLink) — deploy: shopeeAffiliateGraphql
VITE_AFFILIATE_GRAPHQL_URL=https://southamerica-east1-projetoafiliado-9ff07.cloudfunctions.net/shopeeAffiliateGraphql
